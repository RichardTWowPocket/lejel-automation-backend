# Backend Configuration
PORT=3000
NODE_ENV=production

# CORS: frontend origin (e.g. Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL only)
# Docker Compose sets DATABASE_URL automatically. For local dev without Docker, use one of:
# - DATABASE_URL=postgresql://lejel:lejel_password@localhost:5432/lejel
# - Or set POSTGRES_HOST (and optionally POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_PORT)
DATABASE_URL=postgresql://lejel:lejel_password@localhost:5432/lejel
POSTGRES_USER=lejel
POSTGRES_PASSWORD=lejel_password
POSTGRES_DB=lejel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT for script-input app auth (register/login)
JWT_SECRET=your-jwt-secret-change-in-production

# n8n webhook: trigger pipeline when user clicks "Generate video"
N8N_WEBHOOK_URL=
# Callback: n8n calls this when done; must match X-Callback-Secret
CALLBACK_SECRET=your-callback-secret
# Base URL of this backend (for building callback URL)
BASE_URL=http://localhost:3000

# Redis (for BullMQ video-rendering queue). Docker Compose sets REDIS_HOST=lejel-redis.
# For local dev without Docker: REDIS_HOST=localhost REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Whisper Worker Service URL (used by backend to communicate with worker)
WHISPER_SERVICE_URL=http://whisper-worker:8000

# API Key for protecting endpoints (transcription, video APIs)
# Use this key in X-API-Key header or Authorization: Bearer <key>
API_KEY=your-secret-api-key-here

# OAuth2 / YouTube - each connection has its own Google client (see POST /api/oauth/youtube/connections)
# OAUTH_ENCRYPTION_KEY encrypts stored tokens. Generate with: openssl rand -base64 32
OAUTH_ENCRYPTION_KEY=your-32-char-encryption-key-for-tokens!!
