# Database (or use DATABASE_URL)
# POSTGRES_HOST=localhost
# POSTGRES_USER=lejel
# POSTGRES_PASSWORD=lejel_password
# POSTGRES_DB=lejel

# Crawl4AI (Docker on network crawl4ai-service), e.g. http://crawl4ai:11235
CRAWL4AI_BASE_URL=

# Cloudflare R2 (S3-compatible API for user uploads on Generate video)
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
# Optional public base for browser reads (not required if worker uses private API only)
# R2_PUBLIC_BASE_URL=

# Browser uploads use presigned PUT to R2 — your bucket MUST allow your frontend origin in R2 CORS.
# See docs/r2-browser-cors.md

# Kie.ai — Anthropic-compatible proxy at POST /v1/messages (Bearer for api.kie.ai/claude/v1/messages)
# KIE_API_KEY=
